{
  "name": "qrcode-agent-cli-release-automation",
  "private": true,
  "type": "module",
  "description": "Repository-native GitHub Release automation for qrcode-agent-cli",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "release:verify-config": "node scripts/release/verify-release-config.mjs",
    "release:quality-gates": "node scripts/release/run-quality-gates.mjs",
    "release:build-artifact": "node scripts/release/build-cli-artifact.mjs",
    "release:publish-assets": "node scripts/release/publish-skill-to-target-repo.mjs",
    "release:ci": "node scripts/release/run-semantic-release.mjs",
    "release:dry-run": "node scripts/release/run-semantic-release.mjs --dry-run --no-ci",
    "release:install-current": "./scripts/install-current-release.sh"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/exec": "^6.0.0",
    "@semantic-release/github": "^11.0.0",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "conventional-changelog-conventionalcommits": "^7.0.0",
    "semantic-release": "^24.0.0"
  }
}
